{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "docusaurus",
  "frontMatter.content.publicFolder": "static",
  "frontMatter.preview.host": "http://localhost:3000",
  "frontMatter.content.defaultFileType": "mdx",
  "frontMatter.content.pageFolders": [
    {
      "title": "Blog",
      "path": "[[workspace]]/blog",
      "contentTypes": [
        "article"
      ]
    }
  ],
  "frontMatter.taxonomy.seoTitleLength": 60,
  "frontMatter.taxonomy.seoDescriptionLength": 160,
  "frontMatter.taxonomy.tags": [
    "404",
    "accessibility",
    "aide",
    "analytics",
    "animation",
    "animations",
    "api",
    "architecture",
    "automation",
    "automatisation",
    "avatar",
    "build",
    "card",
    "cas-pratiques",
    "cloudflare",
    "cms",
    "code-quality",
    "columns",
    "component",
    "components",
    "conditional-rendering",
    "configuration",
    "content",
    "content-types",
    "contenu",
    "création-contenu",
    "css",
    "custom-page",
    "customization",
    "date",
    "debug-tools",
    "démo",
    "design",
    "developer-experience",
    "docusaurus",
    "eslint",
    "faq",
    "file-structure",
    "front-end",
    "frontmatter-cms",
    "github-actions",
    "glossary",
    "goatcounter",
    "grid",
    "guide",
    "howto",
    "icon",
    "iconify",
    "Iconify",
    "icons",
    "images",
    "infima",
    "javascript",
    "layout",
    "lightbox",
    "linting",
    "live",
    "live-code",
    "logos",
    "mdx",
    "metadata",
    "navigation",
    "optimization",
    "outils",
    "performance",
    "photos",
    "playground",
    "plugin",
    "prettier",
    "privacy",
    "productivité",
    "productivity",
    "progress",
    "questions",
    "react",
    "remark",
    "replacement",
    "responsive-design",
    "rich-results",
    "schema-org",
    "scripts",
    "scroll",
    "seo",
    "SEO",
    "sharp",
    "simple-analytics",
    "skills",
    "spa",
    "static",
    "support",
    "svg",
    "swizzle",
    "time",
    "tooling",
    "tooltip",
    "tree",
    "tutorial",
    "views",
    "vscode",
    "webp",
    "workflow"
  ],
  "frontMatter.taxonomy.customTaxonomy": [
    {
      "id": "series",
      "options": [
        "Api and scripts in Docusaurus",
        "CMS & UI",
        "Design your site",
        "Docusaurus Plugins",
        "infima components",
        "SEO & Analytics",
        "Tools"
      ]
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "article",
      "fileType": "mdx",
      "pageBundle": true,
      "defaultFileName": "index",
      "slugTemplate": "{{title}}",
      "filePrefix": "{{year}}/{{month}}/{{day}}/",
      "previewPath": "blog",
      "trailingSlash": true,
      "clearEmpty": true,
      "fields": [
        {
          "type": "heading",
          "title": "Contenu",
          "name": "heading_content"
        },
        {
          "title": "Titre",
          "name": "title",
          "type": "string",
          "required": true
        },
        {
          "title": "Slug",
          "name": "slug",
          "type": "string",
          "description": "URL de l'article, sans /blog/. Ex : my-article-name",
          "required": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string",
          "description": "Résumé SEO. Au-delà de 160 caractères, Google tronque.",
          "required": true
        },
        {
          "title": "Image de couverture",
          "name": "image",
          "type": "image",
          "isPreviewImage": true
        },
        {
          "title": "Auteurs",
          "name": "authors",
          "type": "choice",
          "multiple": true,
          "choices": [
            "docux"
          ],
          "description": "Doit correspondre à une clé de blog/authors.yml."
        },
        {
          "title": "Date de publication",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true,
          "required": true
        },
        {
          "title": "Dernière mise à jour",
          "name": "last_update",
          "type": "fields",
          "fields": [
            {
              "title": "Date",
              "name": "date",
              "type": "datetime",
              "isModifiedDate": true
            },
            {
              "title": "Auteur",
              "name": "author",
              "type": "choice",
              "choices": [
                "docux"
              ]
            }
          ]
        },
        {
          "title": "Brouillon",
          "name": "draft",
          "type": "draft"
        },
        {
          "type": "divider",
          "name": "divider_taxonomy"
        },
        {
          "type": "heading",
          "title": "Classement",
          "name": "heading_taxonomy"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Tag principal",
          "name": "mainTag",
          "type": "tags",
          "taxonomyLimit": 1,
          "singleValueAsString": true,
          "description": "Un seul tag, utilisé par le composant RelatedPosts."
        },
        {
          "title": "Séries",
          "name": "series",
          "type": "taxonomy",
          "taxonomyId": "series",
          "taxonomyLimit": 1,
          "singleValueAsString": true,
          "description": "Liste éditable depuis le dashboard Front Matter (taxonomie « series »)."
        },
        {
          "title": "Masquer le sommaire",
          "name": "hide_table_of_contents",
          "type": "boolean"
        },
        {
          "title": "Langue",
          "name": "inLanguage",
          "type": "choice",
          "choices": [
            "en",
            "fr-FR"
          ],
          "default": "en",
          "description": "Le blog est publié en anglais ; fr-FR sert aux brouillons en attente de traduction."
        },
        {
          "type": "divider",
          "name": "divider_social"
        },
        {
          "type": "heading",
          "title": "Social",
          "name": "heading_social"
        },
        {
          "title": "Clé du post BlueSky",
          "name": "blueSkyRecordKey",
          "type": "string",
          "description": "Partie après /post/ dans l'URL BlueSky. Active le fil de commentaires."
        }
      ]
    }
  ]
}
